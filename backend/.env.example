PORT=3001

# Banco de dados
# Local sem Docker:
MONGODB_URI=mongodb://localhost:27017/vcm
# Dentro do Docker Compose:
# MONGODB_URI=mongodb://mongo:27017/vcm

# Segurança JWT (use uma string longa e aleatória em produção!)
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# URL do frontend (usada para CORS e links de reset de senha)
# Local: http://localhost | Produção: https://seudominio.com
FRONTEND_URL=http://localhost

# E-mail (Resend - https://resend.com)
# Necessário apenas para reset de senha. Em dev, o link é logado no console.
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=VCM <noreply@yourdomain.com>

# Ambiente
NODE_ENV=development
